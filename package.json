{
  "name": "intro-to-ai-agent-dev",
  "private": true,
  "description": "A collection of example code for AI Agent Development",
  "repository": "github:exKAZUu/intro-to-ai-agent-dev",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "check-all-for-ai": "bun run check-for-ai && bun run test --silent",
    "check-for-ai": "bun install > /dev/null && bun run cleanup && bun run typecheck",
    "cleanup": "bun --bun wb lint --fix --format",
    "format": "bun --bun wb lint --format",
    "lint": "bun --bun wb lint",
    "lint-fix": "bun --bun wb lint --fix",
    "prepare": "lefthook install || true",
    "test": "bun wb test",
    "typecheck": "bun --bun wb typecheck"
  },
  "prettier": "@willbooster/prettier-config",
  "dependencies": {
    "@langchain/core": "1.1.48",
    "@langchain/langgraph": "^1.3.6",
    "@langchain/mcp-adapters": "1.1.3",
    "@langchain/openai": "1.4.7",
    "@langchain/tavily": "1.2.0",
    "@openai/agents": "0.11.6",
    "@tavily/core": "0.7.5",
    "langchain": "1.4.4",
    "openai": "6.42.0",
    "playwright": "1.60.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bun": "1.3.14",
    "@types/micromatch": "4.0.10",
    "@willbooster/biome-config": "4.0.0",
    "@willbooster/prettier-config": "10.4.0",
    "@willbooster/wb": "13.22.11",
    "lefthook": "2.1.9",
    "prettier": "3.8.3",
    "prettier-plugin-java": "2.9.7",
    "sort-package-json": "4.0.0",
    "typescript": "6.0.3"
  }
}
